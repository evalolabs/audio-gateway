# Kiosk audio gateway defaults for Seeed ReSpeaker USB 4 Mic Array.

# ReSpeaker ALSA capture device. Check with: arecord -l
ALSA_DEVICE=plughw:1,0

# PCM stream written to the virtual mic FIFO.
RATE=16000
CHANNELS=1
FRAME_MS=20

# Optional explicit ALSA buffering. Keep 0 to use arecord/ALSA defaults.
ARECORD_PERIOD_SIZE=0
ARECORD_BUFFER_SIZE=0
AUDIO_RETRY_SECONDS=2

# FIFO used by module-pipe-source / PipeWire Pulse compatibility.
# The systemd service sets this to %t/kiosk_customer_mic.fifo.
# For manual runs you can leave this unset or set an absolute path.
# FIFO_PATH=/run/user/1000/kiosk_customer_mic.fifo

# Path to Seeed's usb_4_mic_array repository.
RESPEAKER_REPO=~/Downloads/usb_4_mic_array

# Calibration from the first kiosk test:
# front speaker was measured around 180-185 degrees.
FRONT_CENTER_DEG=180
FRONT_HALF_WINDOW_DEG=35

# Stability windows to avoid opening/closing on a single noisy frame.
OPEN_STABLE_MS=400
# Brief gaps while building toward open do not reset progress (ms).
OPEN_ACCUMULATE_GRACE_MS=120
CLOSE_STABLE_MS=250
# If gate is open and direction stays in front, ignore brief is_voice blips this long (ms).
IN_FRONT_VOICE_DROP_MS=800
# If gate is open and is_voice stays on but DOA briefly leaves the front window (ms).
IN_FRONT_BEAM_DROP_MS=700
POLL_MS=50

# Local browser UI for installers and calibration.
UI_HOST=127.0.0.1
UI_PORT=8765

# Optional: add capture_backlog_frames to each gate_status JSON line (journalctl).
# KIOSK_GATEWAY_DEBUG=1

# FIFO backpressure (Linux): enlarge pipe buffer; longer write wait (defaults shown).
# FIFO_PIPE_SIZE_BYTES=1048576
# FIFO_WRITE_TIMEOUT_S=0.6
# FIFO_PAD_TIMEOUT_S=0.15
